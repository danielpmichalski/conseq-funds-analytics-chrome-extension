{
  "manifest_version": 3,
  "name": "Conseq Analytics",
  "version": "1.0",
  "description": "Adds multiple extra charts below the fund investment chart on Conseq Funds client area.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "host_permissions": ["https://*.conseq.pl/*"],
  "content_scripts": [
    {
      "matches": ["https://*.conseq.pl/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
